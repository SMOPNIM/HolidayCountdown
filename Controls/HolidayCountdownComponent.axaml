<ci:ComponentBase x:TypeArguments="models:HolidayCountdownSettings"
                  x:Class="HolidayCountdown.Controls.HolidayCountdownComponent"
                  xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="clr-namespace:HolidayCountdown.Controls"
                  xmlns:ci="http://classisland.tech/schemas/xaml/core"
                  xmlns:models="clr-namespace:HolidayCountdown.Models"
                  mc:Ignorable="d"
                  d:DesignHeight="60" d:DesignWidth="400">
  <Grid DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:HolidayCountdownComponent}}"
        VerticalAlignment="Center">
    <TextBlock Name="PartDisplayText"
               Text="{Binding DisplayText, Mode=OneWay}"
               FontSize="{Binding Settings.FontSize}"
               VerticalAlignment="Center"
               TextWrapping="NoWrap" />
  </Grid>
</ci:ComponentBase>
