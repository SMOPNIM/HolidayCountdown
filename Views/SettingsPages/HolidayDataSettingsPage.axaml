<ci:SettingsPageBase x:Class="HolidayCountdown.Views.SettingsPages.HolidayDataSettingsPage"
                      xmlns="https://github.com/avaloniaui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:ci="http://classisland.tech/schemas/xaml/core"
                      xmlns:local="clr-namespace:HolidayCountdown.Views.SettingsPages"
                      mc:Ignorable="d"
                      d:DesignHeight="600" d:DesignWidth="800">
  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    <!-- 数据源配置 -->
    <StackPanel Grid.Row="0">
      <TextBlock Text="节假日数据管理" FontSize="20" FontWeight="Bold" Margin="0 0 0 8" />

      <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
        <TextBlock Text="数据源：" VerticalAlignment="Center" Margin="0 0 8 0" />
        <ComboBox Name="DataSourceCombo"
                  SelectedIndex="{Binding DataSourceIndex}"
                  Width="150">
          <ComboBoxItem>仅本地</ComboBoxItem>
          <ComboBoxItem>GitHub</ComboBoxItem>
          <ComboBoxItem>API</ComboBoxItem>
          <ComboBoxItem>Both（API优先）</ComboBoxItem>
        </ComboBox>
      </StackPanel>

      <TextBox Name="GitHubUrlBox" Watermark="GitHub URL: https://raw.githubusercontent.com/..." Margin="0 0 0 4" TextChanged="UrlBox_OnTextChanged" />

      <TextBox Name="ApiUrlBox" Watermark="API URL: https://api.example.com/holidays" Margin="0 0 0 8" TextChanged="UrlBox_OnTextChanged" />

      <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
        <Button Name="BtnRefresh" Classes="Accent" Click="BtnRefresh_OnClick" Margin="0 0 8 0">
          <TextBlock Text="立即更新" />
        </Button>
        <Button Name="BtnReset" Click="BtnReset_OnClick">
          <TextBlock Text="恢复默认" />
        </Button>
      </StackPanel>

      <TextBlock Name="StatusText" FontSize="12" Opacity="0.6" Margin="0 0 0 8" />
    </StackPanel>

    <!-- 节假日列表 -->
    <ScrollViewer Grid.Row="1" Margin="0 8">
      <ItemsControl Name="HolidayList" ItemsSource="{Binding Holidays}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0 0 0 1" Padding="8 4">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="100" />
                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0 0 8 0" />
                <TextBlock Text="{Binding Description}" Opacity="0.6" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- 添加节假日 -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 8 0 0">
      <Button Name="BtnAddHoliday" Click="BtnAddHoliday_OnClick">
        <TextBlock Text="+ 添加节假日" />
      </Button>
    </StackPanel>
  </Grid>
</ci:SettingsPageBase>
